MACROVISION_ENVIRONMENT=development
MACROVISION_DATABASE_URL=sqlite:///./macrovision.db
MACROVISION_LOG_LEVEL=INFO
MACROVISION_MAX_IMPORT_ROWS=1000
MACROVISION_MAX_IMPORT_NOTES_LENGTH=2000
MACROVISION_MAX_IMPORT_ERROR_MESSAGE_LENGTH=500
MACROVISION_FRED_API_KEY=
MACROVISION_FRED_BASE_URL=https://api.stlouisfed.org/fred
MACROVISION_PROVIDER_REQUEST_TIMEOUT_SECONDS=10
MACROVISION_PROVIDER_MAX_OBSERVATIONS=10000
MACROVISION_PROVIDER_MAX_RESPONSE_BYTES=5000000
MACROVISION_PROVIDER_MAX_RETRIES=2
MACROVISION_ENABLE_LIVE_FRED_TESTS=false
